# Backend API base (no trailing slash). WebSocket URL is derived from this host (same port, path /api/ws).
VITE_API_URL=http://localhost:3001/api

# Org invite emails use the backend FRONTEND_URL — set that in gallery-backend/.env to this app’s
# public origin (e.g. http://localhost:5173 in dev) so “Accept invitation” links work.

# Firebase Web (FCM in browser — optional). Copy public/firebase-messaging-config.example.json →
# public/firebase-messaging-config.json (gitignored) with the same values as below.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=   # Firebase Console → Project settings → Cloud Messaging → Web Push certificates

# Dev-only: bypass auth in the UI (no real API session)
# VITE_DEV_FORCE_AUTH=true
